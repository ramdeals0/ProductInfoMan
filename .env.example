DATABASE_URL="postgresql://postgres:postgres@localhost:5432/productinfoman?schema=public"
REDIS_URL="redis://localhost:6379"
IMPORT_SYNC="false"
SEARCH_SYNC="false"
PUBLISH_SYNC="false"
EVENT_SYNC="false"
OPENSEARCH_URL="http://localhost:9200"

# Performance & resilience tuning
METRICS_ENABLED="true"
IMPORT_WORKER_CONCURRENCY=1
PUBLISH_WORKER_CONCURRENCY=1
SEARCH_WORKER_CONCURRENCY=2
EVENT_WORKER_CONCURRENCY=2
IMPORT_BATCH_SIZE=500
PUBLISH_BATCH_SIZE=200
PUBLISH_BATCH_DELAY_MS=50
HEAVY_JOB_QUEUE_THRESHOLD=50
CACHE_CATEGORY_TREE_TTL_SEC=300
REDIS_COMMAND_TIMEOUT_MS=3000
DB_QUERY_TIMEOUT_MS=10000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=30000

# Auth (API + admin must share JWT_SECRET — min 32 characters)
JWT_SECRET="change-me-to-a-long-random-secret-32chars+"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN_PRIVILEGED="24h"
PASSWORD_SALT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
ADMIN_EMAIL="admin@demo.local"
ADMIN_PASSWORD="Admin123!@#demo"
DEMO_USER_PASSWORD="Admin123!@#demo"
HEALTH_INTERNAL_TOKEN="change-me-internal-health-token"

# For local dev without Docker, use Prisma dev:
#   npx prisma dev -d
#   npx prisma dev ls   # copy DATABASE_URL (TCP line)
