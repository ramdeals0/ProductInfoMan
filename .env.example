DATABASE_URL="postgresql://postgres:postgres@localhost:5432/productinfoman?schema=public"
REDIS_URL="redis://localhost:6379"
IMPORT_SYNC="false"
SEARCH_SYNC="false"
PUBLISH_SYNC="false"
EVENT_SYNC="false"
OPENSEARCH_URL="http://localhost:9200"

# Auth (API + admin must share JWT_SECRET — min 32 characters)
JWT_SECRET="change-me-to-a-long-random-secret-32chars+"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"
PASSWORD_SALT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
ADMIN_EMAIL="admin@demo.local"
ADMIN_PASSWORD="Admin123!@#demo"

# For local dev without Docker, use Prisma dev:
#   npx prisma dev -d
#   npx prisma dev ls   # copy DATABASE_URL (TCP line)
