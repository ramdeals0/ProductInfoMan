# Railway environment template
# Copy variable names into each Railway service (Variables tab).
# Use Railway references like ${{Postgres.DATABASE_URL}} where noted.
#
# Generate a shared secret once (API + Admin must match):
#   openssl rand -base64 48

# ─── PostgreSQL (add Railway Postgres plugin) ───────────────────────────────
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ─── API service ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
# PORT is injected automatically by Railway

# Required — min 32 characters; must match Admin JWT_SECRET
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48

# Comma-separated public origins (set after generating domains)
# CORS_ORIGINS=https://${{admin.RAILWAY_PUBLIC_DOMAIN}},https://${{storefront.RAILWAY_PUBLIC_DOMAIN}}

# Run background workers inline (no Redis required on starter setup)
IMPORT_SYNC=true
SEARCH_SYNC=true
PUBLISH_SYNC=true
EVENT_SYNC=true
METRICS_ENABLED=true

# Seed admin user (used by pnpm db:seed in Railway shell)
ADMIN_EMAIL=admin@demo.local
ADMIN_PASSWORD=REPLACE_WITH_strong_password_min_12_chars

# Optional: add Railway Redis and set REDIS_URL, then set *_SYNC=false
# REDIS_URL=${{Redis.REDIS_URL}}

# Optional: external OpenSearch
# OPENSEARCH_URL=

# ─── Admin service ───────────────────────────────────────────────────────────
# API_URL must be set BEFORE the first build (Next.js rewrites).
API_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
JWT_SECRET=REPLACE_WITH_same_value_as_api_JWT_SECRET
NEXT_PUBLIC_DEFAULT_ORG_SLUG=demo
NEXT_PUBLIC_ADMIN_EMAIL=admin@demo.local

# ─── Storefront service ──────────────────────────────────────────────────────
API_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_ORG_SLUG=demo
NEXT_PUBLIC_SITE_URL=https://${{storefront.RAILWAY_PUBLIC_DOMAIN}}

# Optional Stripe (mock checkout when unset)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
