# Railway environment template
# Copy variable names into each Railway service (Variables tab).
# Use Railway references like ${{Postgres.DATABASE_URL}} where noted.

# ─── PostgreSQL (add Railway Postgres plugin) ───────────────────────────────
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ─── API service ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
# PORT is injected automatically by Railway

# Run background workers inline (no Redis required on Railway starter setup)
IMPORT_SYNC=true
SEARCH_SYNC=true
PUBLISH_SYNC=true
EVENT_SYNC=true

# Optional: add Railway Redis and set REDIS_URL, then set *_SYNC=false
# REDIS_URL=${{Redis.REDIS_URL}}

# Optional: add OpenSearch elsewhere and set OPENSEARCH_URL
# Without it, search uses in-memory projection (fine for demo)

# ─── Admin service (set API_URL to your API public domain at build + runtime) ─
API_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_DEFAULT_ORG_SLUG=demo

# ─── Storefront service ────────────────────────────────────────────────────────
# API_URL is required at build time for Next.js rewrites()
API_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_ORG_SLUG=demo
NEXT_PUBLIC_SITE_URL=https://${{storefront.RAILWAY_PUBLIC_DOMAIN}}

# Client-side fetches use same-origin /api rewrites when NEXT_PUBLIC_API_URL is empty
# NEXT_PUBLIC_API_URL=

# Optional Stripe (mock checkout when unset)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
